{
  "name": "dom-to-pptx",
  "version": "2.0.3",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "description": "A client-side library that converts any HTML element into a fully editable PowerPoint slide. **dom-to-pptx** transforms DOM structures into pixel-accurate `.pptx` content, preserving gradients, shadows, rounded images, and responsive layouts. It translates CSS Flexbox/Grid, linear-gradients, box-shadows, and typography into native PowerPoint shapes, enabling precise, design-faithful slide generation directly from the browser.",
  "main": "dist/dom-to-pptx.cjs",
  "module": "dist/dom-to-pptx.mjs",
  "browser": "dist/dom-to-pptx.bundle.js",
  "exports": {
    ".": {
      "import": "./dist/dom-to-pptx.mjs",
      "require": "./dist/dom-to-pptx.cjs",
      "default": "./dist/dom-to-pptx.cjs"
    },
    "./node": {
      "import": "./dist/dom-to-pptx-node.mjs",
      "require": "./dist/dom-to-pptx-node.cjs",
      "default": "./dist/dom-to-pptx-node.cjs"
    },
    "./skills/*": "./skills/*",
    "./bin/cli-skills-installer.js": "./bin/cli-skills-installer.js",
    "./bin/cli-exporter.js": "./bin/cli-exporter.js"
  },
  "bin": {
    "dom-to-pptx": "bin/cli-main.js",
    "dom-to-pptx-exporter": "bin/cli-exporter.js",
    "dom-to-pptx-skills": "bin/cli-skills-installer.js"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "Readme.md",
    "CONTRIBUTORS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npx rollup -c",
    "lint": "eslint .",
    "format": "prettier --write .",
    "publish:all": "pnpm publish -r --no-git-checks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atharva9167j/dom-to-pptx.git"
  },
  "keywords": [
    "ppt",
    "pptx",
    "html-to-pptx",
    "powerpoint",
    "pptx-generator",
    "slide-generator",
    "presentation-generator",
    "dom",
    "dom-to-pptx",
    "export",
    "export-pptx",
    "browser-export",
    "client-side-pptx",
    "html-to-powerpoint",
    "convert-html",
    "css-to-pptx",
    "css-to-powerpoint",
    "pptx-creator",
    "presentation-tools",
    "slides",
    "slide-creation",
    "web-to-pptx",
    "web-to-powerpoint",
    "frontend-pptx",
    "html-rendering",
    "layout-engine",
    "gradient-support",
    "flexbox",
    "css-grid",
    "typography",
    "pptx-skills",
    "ppt-creation-skills",
    "dom-to-pptx-skills",
    "powerpoint-skills"
  ],
  "author": {
