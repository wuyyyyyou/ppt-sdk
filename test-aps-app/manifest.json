      "prefs": [],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "script-src": ["'self'"],
      "style-src": ["'self'"],
      "img-src": ["'self'", "data:", "blob:", "https:"],
      "connect-src": ["'self'", "https:", "blob:"],
      "font-src": ["'self'", "data:"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "seed_storage": {},
    "user_id": 1
  }
