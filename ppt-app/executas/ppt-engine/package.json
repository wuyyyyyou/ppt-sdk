{
  "name": "presenton-template-engine-executa",
  "version": "4.0.4",
  "description": "Presenton template engine vendored into an Anna Executa plugin",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "manifest.json",
    "dist",
    "example_plugin.js",
    "build_binary.sh",
    "scripts/binary-release.mjs",
    "scripts/patch-postject.mjs",
    "scripts/prepare-sea-bundle.mjs",
    "scripts/sea-bootstrap.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/http/server.d.ts",
      "import": "./dist/http/server.js"
    }
  },
  "bin": {
    "presenton-template-engine-server": "./dist/cli.js",
    "tool-lightvoss-ppt-engine-kqhra9hy": "./example_plugin.js"
  },
  "scripts": {
    "sync:tool-manifests": "node ../../scripts/sync-tool-manifests.mjs",
    "sync:engine-manifest": "node ../../scripts/sync-ppt-engine-manifest.mjs",
    "prebuild": "npm run sync:engine-manifest",
    "dev": "tsx src/cli.ts",
    "build": "node ./scripts/build-template-registry.mjs && node ./scripts/preserve-dist-template-previews.mjs save && tsup && node ./scripts/preserve-dist-template-previews.mjs restore && node ./scripts/build-forkable-templates.mjs",
    "build:full": "npm run build && npm run build:template-previews",
    "build:template-previews": "node ./scripts/build-template-previews.mjs",
    "check": "tsc --noEmit",
    "test:unit": "node --import tsx/esm --test test/**/*.test.ts",
    "start": "node dist/cli.js",
    "start:plugin": "node example_plugin.js",
    "build:binary": "./build_binary.sh",
    "test": "node -e \"console.log('No vendored automated tests in this example package')\""
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "esbuild": "^0.27.4",
    "pptx-svg": "^0.6.4",
    "puppeteer": "24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "use-resize-observer": "^9.1.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "@types/react": "^18.3.24",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.5.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pkg": {
    "assets": [
      "manifest.json",
      "dist/browser/*.global.js",
      "dist/forkable-templates/**/*",
      "dist/template-previews/**/*",
      "node_modules/**/*.cjs",
      "node_modules/**/*.mjs",
      "node_modules/**/*.wasm",
      "node_modules/**/*.json"
    ],
    "scripts": [
      "dist/**/*.js",
      "node_modules/**/*.js"
    ]
  }
}
