{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "chart-analytics-v1 theme tokens",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode", "colors", "shadows"],
  "properties": {
    "version": {
      "const": 1
    },
    "mode": {
      "enum": ["light", "dark"]
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canvas",
        "surface",
        "card",
        "textPrimary",
        "textMuted",
        "textSubtle",
        "textInverse",
        "stroke",
        "strokeSoft",
        "grid",
        "darkCanvas",
        "darkPanel",
        "darkText",
        "darkMutedText",
        "darkBorder",
        "darkCallout",
        "signalPrimary",
        "signalPrimaryTint",
        "signalPrimaryBorder",
        "signalSecondary",
        "signalSecondaryTint",
        "signalSecondaryBorder",
        "signalTertiary",
        "signalTertiaryTint",
        "signalTertiaryBorder",
        "signalRisk",
        "signalRiskTint",
        "signalRiskBorder",
        "signalWarning",
        "signalWarningTint",
        "signalWarningBorder",
        "signalSuccess",
        "signalSuccessTint",
        "signalSuccessBorder",
        "signalNeutral",
        "signalNeutralTint",
        "signalNeutralBorder",
        "entityPrimary",
        "entityPrimaryTint",
        "entityPrimaryBorder",
        "entitySecondary",
        "entitySecondaryTint",
        "entitySecondaryBorder",
        "chart1",
        "chart2",
        "chart3",
        "chart4",
        "chart5",
        "chart6",
        "chartStructureSegment1",
        "chartStructureSegment2",
        "chartStructureSegment3"
      ],
      "properties": {
        "canvas": { "$ref": "#/$defs/hexColor" },
        "surface": { "$ref": "#/$defs/hexColor" },
        "card": { "$ref": "#/$defs/hexColor" },
        "textPrimary": { "$ref": "#/$defs/hexColor" },
        "textMuted": { "$ref": "#/$defs/hexColor" },
        "textSubtle": { "$ref": "#/$defs/hexColor" },
        "textInverse": { "$ref": "#/$defs/hexColor" },
        "stroke": { "$ref": "#/$defs/hexColor" },
        "strokeSoft": { "$ref": "#/$defs/hexColor" },
        "grid": { "$ref": "#/$defs/hexColor" },
        "darkCanvas": { "$ref": "#/$defs/hexColor" },
        "darkPanel": { "$ref": "#/$defs/hexColor" },
        "darkText": { "$ref": "#/$defs/hexColor" },
        "darkMutedText": { "$ref": "#/$defs/hexColor" },
        "darkBorder": { "$ref": "#/$defs/hexColor" },
        "darkCallout": { "$ref": "#/$defs/hexColor" },
        "signalPrimary": { "$ref": "#/$defs/hexColor" },
        "signalPrimaryTint": { "$ref": "#/$defs/hexColor" },
        "signalPrimaryBorder": { "$ref": "#/$defs/hexColor" },
        "signalSecondary": { "$ref": "#/$defs/hexColor" },
        "signalSecondaryTint": { "$ref": "#/$defs/hexColor" },
        "signalSecondaryBorder": { "$ref": "#/$defs/hexColor" },
        "signalTertiary": { "$ref": "#/$defs/hexColor" },
        "signalTertiaryTint": { "$ref": "#/$defs/hexColor" },
        "signalTertiaryBorder": { "$ref": "#/$defs/hexColor" },
        "signalRisk": { "$ref": "#/$defs/hexColor" },
        "signalRiskTint": { "$ref": "#/$defs/hexColor" },
        "signalRiskBorder": { "$ref": "#/$defs/hexColor" },
        "signalWarning": { "$ref": "#/$defs/hexColor" },
        "signalWarningTint": { "$ref": "#/$defs/hexColor" },
        "signalWarningBorder": { "$ref": "#/$defs/hexColor" },
        "signalSuccess": { "$ref": "#/$defs/hexColor" },
        "signalSuccessTint": { "$ref": "#/$defs/hexColor" },
        "signalSuccessBorder": { "$ref": "#/$defs/hexColor" },
        "signalNeutral": { "$ref": "#/$defs/hexColor" },
        "signalNeutralTint": { "$ref": "#/$defs/hexColor" },
        "signalNeutralBorder": { "$ref": "#/$defs/hexColor" },
        "entityPrimary": { "$ref": "#/$defs/hexColor" },
        "entityPrimaryTint": { "$ref": "#/$defs/hexColor" },
        "entityPrimaryBorder": { "$ref": "#/$defs/hexColor" },
        "entitySecondary": { "$ref": "#/$defs/hexColor" },
        "entitySecondaryTint": { "$ref": "#/$defs/hexColor" },
        "entitySecondaryBorder": { "$ref": "#/$defs/hexColor" },
        "chart1": { "$ref": "#/$defs/hexColor" },
        "chart2": { "$ref": "#/$defs/hexColor" },
        "chart3": { "$ref": "#/$defs/hexColor" },
        "chart4": { "$ref": "#/$defs/hexColor" },
        "chart5": { "$ref": "#/$defs/hexColor" },
        "chart6": { "$ref": "#/$defs/hexColor" },
        "chartStructureSegment1": { "$ref": "#/$defs/hexColor" },
        "chartStructureSegment2": { "$ref": "#/$defs/hexColor" },
        "chartStructureSegment3": { "$ref": "#/$defs/hexColor" }
      }
    },
    "shadows": {
      "type": "object",
      "additionalProperties": false,
      "required": ["card", "panel", "darkPanel", "soft"],
      "properties": {
        "card": { "type": "string", "minLength": 1 },
        "panel": { "type": "string", "minLength": 1 },
        "darkPanel": { "type": "string", "minLength": 1 },
        "soft": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    }
  }
}
