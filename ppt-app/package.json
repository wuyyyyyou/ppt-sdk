{
  "name": "ppt-app",
  "private": true,
  "version": "0.1.0",
  "description": "Anna App workspace for the PPT generation workflow.",
  "type": "module",
  "scripts": {
    "sync:template-previews": "node ./scripts/sync-template-previews.mjs",
    "predev": "npm run sync:template-previews",
    "predev:mock-llm": "npm run sync:template-previews",
    "predev:mock-llm:retry": "npm run sync:template-previews",
    "prebuild": "npm run sync:template-previews",
    "dev": "anna-app dev",
    "dev:mock-llm": "anna-app dev --mock-llm fixtures/mock-outline.jsonl",
    "dev:mock-llm:retry": "anna-app dev --mock-llm fixtures/mock-outline-retry.jsonl",
    "build": "vite build --outDir bundle",
    "check": "tsc --noEmit",
    "test:unit": "node --import tsx/esm --test tests/**/*.test.ts",
    "validate": "anna-app validate --strict"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@anna-ai/cli": "^0.1.12",
    "@types/node": "^20.19.17",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.2",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
