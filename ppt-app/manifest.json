{
  "schema": 2,
  "permissions": [
    "tools.invoke"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:ppt-engine",
      "min_version": "3.2.1",
      "version": "latest"
    },
    {
      "tool_id": "bundled:ppt-gener",
      "min_version": "3.1.1",
      "version": "latest"
    },
    {
      "tool_id": "bundled:anna-search",
      "version": "latest",
      "min_version": "0.1.0"
    }
  ],
  "optional_executas": [],
  "tags": [
    "presentation",
    "ppt",
    "workflow"
  ],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "PPT App",
        "default": true,
        "entry": "index.html",
        "min_size": {
          "w": 900,
          "h": 720
        },
        "default_size": {
          "w": 1080,
          "h": 760
        },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": [
        "required:bundled:ppt-engine",
        "required:bundled:ppt-gener",
        "required:bundled:anna-search"
      ],
      "chat": [],
      "artifact": [],
      "llm": [
        "complete"
      ],
      "agent": {
        "session": {
          "auto": true,
          "fixed": null
        },
        "tools": []
      },
      "fs": [],
      "storage": [],
      "prefs": [],
      "window": []
    },
    "csp_overrides": {
      "img-src": [
        "'self'",
        "data:",
        "blob:",
        "http://127.0.0.1:*",
        "http://localhost:*"
      ],
      "font-src": [
        "'self'",
        "data:"
      ],
      "style-src": [
        "'self'"
      ],
      "script-src": [
        "'self'"
      ]
    }
  }
}
