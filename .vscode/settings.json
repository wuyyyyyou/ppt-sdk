{
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "python.defaultInterpreterPath": "${workspaceFolder}/presenton-pptx-generator/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/presenton-pptx-generator/src"
  ],
  "files.exclude": {
    "**/.DS_Store": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/dist/**": true,
    "**/node_modules/**": true
  }
}
