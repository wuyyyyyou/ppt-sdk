{
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "python.analysis.extraPaths": [
    "${workspaceFolder}/ppt-app/executas/ppt-gener/src",
    "${workspaceFolder}/ppt-app/executas/anna-search/src"
  ],
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.idea": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/node_modules": true,
    "**/.idea": true,
    ".vscode/pipeline-output": true
  },
  "files.watcherExclude": {
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/.idea": true,
    ".vscode/pipeline-output/**": true
  }
}
