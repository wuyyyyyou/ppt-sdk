{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PPT: Build Template Engine",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ppt-app/executas/ppt-engine"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PPT: Check Environment",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}/ppt-app/scripts/run-ppt-pipeline.mjs",
        "check-env"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PPT: Generate PPTX From Current Manifest",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}/ppt-app/scripts/run-ppt-pipeline.mjs",
        "generate",
        "--require-manifest-json-name",
        "1",
        "--manifest",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "PPT: Build Template Engine"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    },
    {
      "label": "PPT: Generate PPTX From Current TSX",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}/ppt-app/scripts/run-ppt-pipeline.mjs",
        "generate-tsx",
        "--entry",
        "${file}",
        "--rasterize",
        "1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "PPT: Build Template Engine"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    },
    {
      "label": "PPT: Generate From Current File",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}/ppt-app/scripts/run-ppt-pipeline.mjs",
        "generate-current",
        "--file",
        "${file}",
        "--rasterize",
        "1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    }
  ]
}
