{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Presenton: Plugin",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/.vscode/engine/run-plugin-once.mjs",
      "env": {
        "ENGINE_STDIN_FILE": "${workspaceFolder}/.vscode/engine/describe-stdin.json",
        "ENGINE_STDOUT_FILE": "${workspaceFolder}/.vscode/engine/stdout.json"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
