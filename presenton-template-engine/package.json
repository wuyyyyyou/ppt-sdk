{
  "name": "presenton-template-engine-executa",
  "version": "0.0.3",
  "description": "Presenton template engine vendored into an Anna Executa plugin",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "example_plugin.js",
    "build_binary.sh",
    "scripts/patch-postject.mjs",
    "scripts/prepare-sea-bundle.mjs",
    "scripts/sea-bootstrap.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/http/server.d.ts",
      "import": "./dist/http/server.js",
      "require": "./dist/http/server.cjs"
    }
  },
  "bin": {
    "presenton-template-engine-server": "./dist/cli.js",
    "ppt-engine": "./example_plugin.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node ./scripts/build-template-registry.mjs && tsup && node ./scripts/build-forkable-templates.mjs",
    "check": "tsc --noEmit",
    "test:unit": "node --import tsx/esm --test test/**/*.test.ts",
    "start": "node dist/cli.js",
    "start:plugin": "node example_plugin.js",
    "build:binary": "./build_binary.sh",
    "test": "node -e \"console.log('No vendored automated tests in this example package')\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "puppeteer": "24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "@types/react": "^18.3.24",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pkg": {
    "assets": [
      "dist/browser/*.global.js",
      "dist/forkable-templates/**/*",
      "node_modules/**/*.cjs",
      "node_modules/**/*.mjs",
      "node_modules/**/*.json"
    ],
    "scripts": [
      "dist/**/*.js",
      "node_modules/**/*.js"
    ]
  }
}
