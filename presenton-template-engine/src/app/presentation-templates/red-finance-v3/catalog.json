{
  "group_id": "red-finance-v3",
  "catalog_type": "tsx-first",
  "version": 2,
  "purpose": "Help the PPT AI Agent choose a copyable TSX blueprint page first, derive it into slides/*.tsx, and then edit the final slide implementation directly.",
  "directory_roles": {
    "blueprints": {
      "path": "./blueprints",
      "role": "Directory of copyable TSX blueprint pages.",
      "rules": [
        "Start here by selecting the blueprint page closest to the content structure.",
        "Copy it into ./slides before adapting it for the concrete deck.",
        "Do not treat this directory as a runtime JSON DSL."
      ]
    },
    "slides": {
      "path": "./slides",
      "role": "Directory of final slide pages for the concrete deck.",
      "rules": [
        "manifest.json should only point to TSX files in this directory.",
        "AI may edit TSX here directly to adjust layout, component composition, and content mapping.",
        "Slides here should not remain unchanged blueprint copies for long."
      ]
    },
    "reference_slides": {
      "path": "./reference-slides",
      "role": "Read-only reference slides for visual density, component composition, and export conventions.",
      "rules": [
        "Use them only to inspect visual density, component composition, and export conventions.",
        "Do not add them to group.json.layouts.",
        "Do not use them as manifest.json source.path values."
      ]
    },
    "data": {
      "path": "./data",
      "role": "Content data for demo slides or concrete decks.",
      "rules": [
        "JSON should carry content only, not page-structure decisions.",
        "If layout overflows or a component is unsuitable, prefer editing slides/*.tsx."
      ]
    }
  },
  "blueprints": [
    {
      "id": "cover-statement",
      "name": "Cover Statement",
      "blueprint_source": "./blueprints/CoverStatement.tsx",
      "example_slide": "./slides/CoverStatement.tsx",
      "layout_family": "cover",
      "content_intents": ["opening", "positioning", "theme-statement"],
      "suitable_for": ["cover", "strategy report opening", "theme statement", "executive briefing opening"],
      "avoid_for": ["body analysis", "complex charts", "comparison matrix", "long process explanation"]
    },
    {
      "id": "section-divider",
