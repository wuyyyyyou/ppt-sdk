{
  "id": "timeline-plan",
  "name": "Timeline Plan",
  "description": "Timeline or roadmap structure for phases, milestones, regulatory evolution, or implementation plans.",
  "implementation_status": "implemented",
  "slide_renderer": "./slides/TimelinePlan.tsx",
  "layout_family": "timeline",
  "content_intents": ["roadmap", "milestones", "sequence", "implementation"],
  "suitable_for": ["战略路线图", "实施节奏", "行业演进", "政策里程碑"],
  "avoid_for": ["无顺序分类", "多维矩阵", "单图表分析", "KPI 汇总"],
  "slots": [
    {
      "name": "timeline-core",
      "purpose": "按阶段或时间顺序展示关键节点",
      "required": true,
      "allowed_component_families": ["timeline", "card"],
      "allowed_components": ["TimelineBoard", "VerticalMilestoneTimeline", "HorizontalFeatureCard"],
      "content_type": "timeline",
      "min_items": 3,
      "max_items": 6,
      "text_limits": { "title_max": 24, "body_max": 80, "label_max": 18 },
      "can_reorder": true,
      "can_replace": true
    },
    {
      "name": "roadmap-context",
      "purpose": "说明路线图目标、阶段逻辑和关键依赖",
      "required": true,
      "allowed_component_families": ["heading", "callout"],
      "allowed_components": ["FinanceSectionHeading", "InsightCallout"],
      "content_type": "editable-text",
      "min_items": 1,
      "max_items": 3,
      "text_limits": { "title_max": 30, "body_max": 120 },
      "can_reorder": false,
      "can_replace": true
    },
    {
      "name": "stage-metrics",
      "purpose": "可选阶段目标、进度或成功标准",
      "required": false,
      "allowed_component_families": ["kpi", "primitive"],
      "allowed_components": ["KpiMetricItem", "ProgressStatusCard", "StatusPill"],
      "content_type": "kpi",
      "min_items": 0,
      "max_items": 4,
      "text_limits": { "title_max": 22, "body_max": 60, "label_max": 16 },
      "can_reorder": true,
      "can_replace": true
    }
  ],
  "variants": [
    {
      "id": "horizontal-roadmap",
      "name": "Horizontal Roadmap",
      "description": "横向阶段路线图，适合年度计划或实施路径。",
      "best_for": ["三到五阶段计划", "年度路线图", "项目节奏"]
    },
    {
      "id": "vertical-milestones",
      "name": "Vertical Milestones",
      "description": "纵向里程碑叙事，适合历史演进或政策进程。",
      "best_for": ["政策时间线", "行业发展", "产品演进"]
    }
  ],
  "density_range": ["medium", "high"],
  "component_families": ["timeline", "card", "heading", "callout", "kpi", "primitive"],
  "agent_selection_rules": [
    "当内容存在明确先后顺序、阶段或里程碑时选择。",
    "如果节点之间没有时间或依赖关系，应选择 three-column-cards。",
    "阶段超过 6 个时应合并或拆页。"
  ],
  "export_notes": [
    "时间标签、阶段标题、里程碑说明和 KPI 必须保持真实文本。",
    "连接线和节点装饰可以截图兜底。",
    "避免依赖颜色表示阶段状态，需保留文字状态。"
  ]
}
