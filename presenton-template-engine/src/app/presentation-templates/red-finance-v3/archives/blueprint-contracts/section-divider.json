{
  "id": "section-divider",
  "name": "Section Divider",
  "description": "Chapter transition structure with a section statement and a small set of framing cards.",
  "implementation_status": "implemented",
  "slide_renderer": "./slides/SectionDivider.tsx",
  "layout_family": "section",
  "content_intents": ["transition", "framing", "section-introduction"],
  "suitable_for": ["章节分隔", "主题切换", "分析框架引入", "方法说明"],
  "avoid_for": ["指标汇总", "细节对比", "长时间线", "大段正文"],
  "slots": [
    {
      "name": "section-statement",
      "purpose": "章节编号、短标题和导语，定义当前章节的叙事边界",
      "required": true,
      "allowed_component_families": ["heading", "primitive"],
      "allowed_components": ["FinanceSectionFocusFrame", "FinanceIcon"],
      "content_type": "editable-text",
      "min_items": 2,
      "max_items": 4,
      "text_limits": { "title_max": 26, "body_max": 96, "label_max": 24 },
      "can_reorder": false,
      "can_replace": false
    },
    {
      "name": "framing-cards",
      "purpose": "用少量卡片提示本章节的结构、重点或判断维度",
      "required": false,
      "allowed_component_families": ["card", "primitive"],
      "allowed_components": ["HorizontalFeatureCard", "FinanceIcon"],
      "content_type": "cards",
      "min_items": 2,
      "max_items": 4,
      "text_limits": { "title_max": 32, "body_max": 90, "label_max": 16 },
      "can_reorder": true,
      "can_replace": true
    }
  ],
  "variants": [
    {
      "id": "left-statement-right-cards",
      "name": "Left Statement Right Cards",
      "description": "左侧章节声明，右侧 2-4 张框架卡。",
      "best_for": ["方法框架", "章节开场", "重点预告"]
    },
    {
      "id": "minimal-statement",
      "name": "Minimal Statement",
      "description": "只保留章节编号、标题和短导语，弱化右侧内容。",
      "best_for": ["快速转场", "低密度汇报", "视觉停顿"]
    }
  ],
  "density_range": ["low", "medium"],
  "component_families": ["heading", "primitive", "card"],
  "agent_selection_rules": [
    "当内容大纲进入新章节，但还不需要承载完整分析时选择。",
    "如果右侧卡片超过 4 张或每张需要长正文，应换成 three-column-cards 或 two-column-insight。",
    "章节标题要短，导语只说明该章节回答的问题。"
  ],
  "export_notes": [
    "章节编号、标题、导语和卡片文字必须保持真实文本。",
    "右侧卡片图标可以作为矢量或截图兜底，但不要承载唯一含义。",
    "避免卡片高度依赖动态内容撑开。"
  ]
}
