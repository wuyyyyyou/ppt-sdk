{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presenton.local/templates/red-finance-v3/blueprints/schema.json",
  "title": "Red Finance V3 Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "implementation_status",
    "slide_renderer",
    "layout_family",
    "content_intents",
    "suitable_for",
    "avoid_for",
    "slots",
    "variants",
    "density_range",
    "component_families",
    "agent_selection_rules",
    "export_notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "description": {
      "type": "string",
      "minLength": 8
    },
    "implementation_status": {
      "type": "string",
      "enum": ["implemented", "planned"]
    },
    "slide_renderer": {
      "type": "string",
      "pattern": "^\\.\\/slides\\/[A-Za-z0-9]+\\.tsx$"
    },
    "layout_family": {
      "type": "string",
      "enum": [
        "cover",
        "section",
        "two-column",
        "three-column",
        "chart-narrative",
        "matrix",
        "timeline",
        "kpi",
        "closing"
      ]
    },
    "content_intents": {
      "$ref": "#/$defs/stringArray"
    },
    "suitable_for": {
      "$ref": "#/$defs/stringArray"
    },
    "avoid_for": {
      "$ref": "#/$defs/stringArray"
    },
    "slots": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "variants": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/variant"
      }
    },
    "density_range": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["low", "medium", "high"]
      }
    },
    "component_families": {
      "$ref": "#/$defs/stringArray"
    },
    "agent_selection_rules": {
      "$ref": "#/$defs/stringArray"
    },
    "export_notes": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "textLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title_max": {
          "type": "integer",
          "minimum": 1
        },
        "body_max": {
          "type": "integer",
          "minimum": 1
        },
        "label_max": {
          "type": "integer",
          "minimum": 1
        },
        "items_max": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "purpose",
        "required",
        "allowed_component_families",
        "allowed_components",
        "content_type",
        "min_items",
        "max_items",
        "text_limits",
        "can_reorder",
        "can_replace"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "purpose": {
          "type": "string",
          "minLength": 4
        },
        "required": {
          "type": "boolean"
        },
        "allowed_component_families": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_components": {
          "$ref": "#/$defs/stringArray"
        },
        "content_type": {
          "type": "string",
          "enum": [
            "editable-text",
            "meta",
            "list",
            "cards",
            "kpi",
            "chart",
            "matrix",
            "timeline",
            "actions",
            "decoration"
          ]
        },
        "min_items": {
          "type": "integer",
          "minimum": 0
        },
        "max_items": {
          "type": "integer",
          "minimum": 1
        },
        "text_limits": {
          "$ref": "#/$defs/textLimits"
        },
        "can_reorder": {
          "type": "boolean"
        },
        "can_replace": {
          "type": "boolean"
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "best_for"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 2
        },
        "description": {
          "type": "string",
          "minLength": 4
        },
        "best_for": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
