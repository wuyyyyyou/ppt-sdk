{
  "id": "chart-with-narrative",
  "name": "Chart With Narrative",
  "description": "Single primary chart paired with narrative interpretation, assumptions, and a concise conclusion.",
  "implementation_status": "implemented",
  "slide_renderer": "./slides/ChartWithNarrative.tsx",
  "layout_family": "chart-narrative",
  "content_intents": ["trend", "scale", "structure-change", "evidence"],
  "suitable_for": ["趋势分析", "规模变化", "结构变化", "预测说明"],
  "avoid_for": ["无数据观点", "多主体大矩阵", "流程计划", "封面转场"],
  "slots": [
    {
      "name": "chart-panel",
      "purpose": "主图表区域，承载一张趋势、结构或规模图",
      "required": true,
      "allowed_component_families": ["chart"],
      "allowed_components": ["ChartCardShell", "MeasuredChartArea", "FinanceBarChart", "FinanceLineChart", "FinanceDonutChart"],
      "content_type": "chart",
      "min_items": 1,
      "max_items": 1,
      "text_limits": { "title_max": 36, "label_max": 18 },
      "can_reorder": false,
      "can_replace": true
    },
    {
      "name": "narrative-panel",
      "purpose": "解释图表的变化原因、判断和业务含义",
      "required": true,
      "allowed_component_families": ["heading", "list", "callout"],
      "allowed_components": ["FinanceSectionHeading", "InfoListItem", "InsightCallout"],
      "content_type": "editable-text",
      "min_items": 2,
      "max_items": 5,
      "text_limits": { "title_max": 28, "body_max": 110 },
      "can_reorder": true,
      "can_replace": true
    },
    {
      "name": "source-note",
      "purpose": "数据口径、来源或预测假设说明",
      "required": false,
      "allowed_component_families": ["primitive"],
      "allowed_components": ["IconText"],
      "content_type": "meta",
      "min_items": 0,
      "max_items": 2,
      "text_limits": { "label_max": 80 },
      "can_reorder": false,
      "can_replace": true
    }
  ],
  "variants": [
    {
      "id": "large-chart-right-notes",
      "name": "Large Chart Right Notes",
      "description": "左侧大图表，右侧解释与结论。",
      "best_for": ["趋势图", "规模变化", "预测曲线"]
    },
    {
      "id": "top-chart-bottom-insight",
      "name": "Top Chart Bottom Insight",
      "description": "上方横向图表，下方三段解释或结论条。",
      "best_for": ["宽图表", "结构变化", "渠道占比"]
    }
  ],
  "density_range": ["medium", "high"],
  "component_families": ["chart", "heading", "list", "callout", "primitive"],
  "agent_selection_rules": [
    "当页面只有一个核心数据证据，并且需要解释它的含义时选择。",
    "如果需要同时比较多个主体和多个维度，应使用 comparison-matrix。",
    "如果没有明确数据或图表，不要为了装饰使用此蓝图。"
  ],
  "export_notes": [
    "图表标题、轴标签、数据来源和结论文字应保持可编辑文本。",
    "Recharts 图表区域允许截图兜底，但旁边叙事必须保留 DOM 文本。",
    "不要把数据口径写进图片。"
  ]
}
