{
  "id": "comparison-matrix",
  "name": "Comparison Matrix",
  "description": "Structured comparison matrix for entities, strategies, markets, capabilities, or solution options.",
  "implementation_status": "implemented",
  "slide_renderer": "./slides/ComparisonMatrix.tsx",
  "layout_family": "matrix",
  "content_intents": ["comparison", "evaluation", "tradeoff", "benchmark"],
  "suitable_for": ["中美对比", "方案对比", "能力矩阵", "市场结构比较"],
  "avoid_for": ["单一叙事", "时间演进", "封面", "超过 6 行的大表"],
  "slots": [
    {
      "name": "matrix-core",
      "purpose": "核心对比表格或能力矩阵",
      "required": true,
      "allowed_component_families": ["matrix"],
      "allowed_components": ["StableMatrixGrid", "ComparisonPanel"],
      "content_type": "matrix",
      "min_items": 2,
      "max_items": 6,
      "text_limits": { "title_max": 24, "body_max": 70, "label_max": 18 },
      "can_reorder": true,
      "can_replace": true
    },
    {
      "name": "comparison-context",
      "purpose": "解释对比维度、评价标准和关键结论",
      "required": true,
      "allowed_component_families": ["heading", "callout", "list"],
      "allowed_components": ["FinanceSectionHeading", "InsightCallout", "InfoListItem"],
      "content_type": "editable-text",
      "min_items": 1,
      "max_items": 3,
      "text_limits": { "title_max": 30, "body_max": 120 },
      "can_reorder": true,
      "can_replace": true
    },
    {
      "name": "status-markers",
      "purpose": "可选状态、评分或高亮标识",
      "required": false,
      "allowed_component_families": ["primitive", "kpi"],
      "allowed_components": ["StatusPill", "KpiMetricItem"],
      "content_type": "kpi",
      "min_items": 0,
      "max_items": 6,
      "text_limits": { "label_max": 16 },
      "can_reorder": true,
      "can_replace": true
    }
  ],
  "variants": [
    {
      "id": "entity-by-dimension",
      "name": "Entity By Dimension",
      "description": "列为主体，行为评价维度。",
      "best_for": ["国家对比", "公司对比", "方案对比"]
    },
    {
      "id": "capability-heatmap",
      "name": "Capability Heatmap",
      "description": "能力项按成熟度或评分高亮。",
      "best_for": ["能力评估", "差距诊断", "优先级排序"]
    }
  ],
  "density_range": ["medium", "high"],
  "component_families": ["matrix", "heading", "callout", "list", "primitive", "kpi"],
  "agent_selection_rules": [
    "当内容需要横向比较至少两个主体和多个维度时选择。",
    "如果比较项超过 6 行或每格需要长段正文，应拆成多页。",
    "如果只是两个值的简单对比，可用 two-column-insight 或 kpi-summary。"
  ],
  "export_notes": [
    "矩阵单元格文字、行列标题和评分标签应保持真实文本。",
    "避免使用图片化大表格。",
    "高亮颜色不能是唯一语义，需保留文字标签。"
  ]
}
