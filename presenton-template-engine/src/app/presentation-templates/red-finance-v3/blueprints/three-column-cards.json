{
  "id": "three-column-cards",
  "name": "Three Column Cards",
  "description": "Three-column card structure for parallel pillars, opportunities, risks, capabilities, or recommendations.",
  "implementation_status": "implemented",
  "slide_renderer": "./slides/ThreeColumnCards.tsx",
  "layout_family": "three-column",
  "content_intents": ["categorization", "pillars", "options", "recommendations"],
  "suitable_for": ["能力支柱", "机会问题策略", "三类方案", "风险分类"],
  "avoid_for": ["单一深度观点", "时间线", "大表格", "趋势图"],
  "slots": [
    {
      "name": "page-frame",
      "purpose": "页面标题、右上元信息、页脚和基本内容框架",
      "required": true,
      "allowed_component_families": ["page-shell", "heading"],
      "allowed_components": ["FinanceContentFrame", "FinanceSectionHeading"],
      "content_type": "editable-text",
      "min_items": 1,
      "max_items": 3,
      "text_limits": { "title_max": 28, "body_max": 80 },
      "can_reorder": false,
      "can_replace": false
    },
    {
      "name": "card-columns",
      "purpose": "三列并列卡片，用于表达同级分类或并行策略",
      "required": true,
      "allowed_component_families": ["card", "primitive", "kpi"],
      "allowed_components": ["PillarBulletCard", "IconTextCard", "HorizontalFeatureCard", "KpiMetricItem"],
      "content_type": "cards",
      "min_items": 3,
      "max_items": 6,
      "text_limits": { "title_max": 24, "body_max": 90, "items_max": 4 },
      "can_reorder": true,
      "can_replace": true
    },
    {
      "name": "summary-strip",
      "purpose": "底部总结条或关键提醒，收束三列信息",
      "required": false,
      "allowed_component_families": ["callout", "card"],
      "allowed_components": ["InsightCallout", "SectionPanelShell"],
      "content_type": "editable-text",
      "min_items": 0,
      "max_items": 1,
      "text_limits": { "body_max": 120 },
      "can_reorder": false,
      "can_replace": true
    }
  ],
  "variants": [
    {
      "id": "three-equal-columns",
      "name": "Three Equal Columns",
      "description": "三列等宽，每列一个支柱或类别。",
      "best_for": ["三大战略", "三类风险", "三项机会"]
    },
    {
      "id": "six-compact-cards",
      "name": "Six Compact Cards",
      "description": "两行三列紧凑卡片，适合列出 4-6 个同级要点。",
      "best_for": ["能力清单", "应用场景", "问题集合"]
    }
  ],
  "density_range": ["medium", "high"],
  "component_families": ["page-shell", "heading", "card", "primitive", "kpi", "callout"],
  "agent_selection_rules": [
    "当内容天然是 3 个同级分组或 4-6 个短卡片时选择。",
    "如果每组内部需要超过 4 条 bullet，应拆页或改用 two-column-insight。",
    "不要用它表达强时间顺序或双主体对比。"
  ],
  "export_notes": [
    "卡片标题、bullet 和总结条必须保持真实文本。",
    "卡片数量变化时保持固定列宽，避免自动撑开页面。",
    "图标只是辅助，不应替代卡片标题。"
  ]
}
