{
  "group_id": "red-blue",
  "catalog_type": "tsx-first",
  "version": 2,
  "purpose": "Help the PPT AI Agent choose a copyable red-blue TSX blueprint page first, derive it into slides/*.tsx, and then edit the final slide implementation directly.",
  "directory_roles": {
    "components": {
      "path": "./components",
      "role": "Reusable TSX visual components extracted from the red-blue HTML reference pages.",
      "rules": [
        "Use these components when building blueprints and concrete slides.",
        "Do not copy raw HTML, inline scripts, Chart.js, ECharts, or external CDN dependencies into final slides.",
        "Keep component props content-oriented and let slides/*.tsx control page-specific layout."
      ]
    },
    "blueprints": {
      "path": "./blueprints",
      "role": "Directory of copyable TSX blueprint pages.",
      "rules": [
        "Start here by selecting the blueprint page closest to the requested content structure.",
        "Copy or derive it into ./slides before adapting it for a concrete deck.",
        "Do not treat this directory as a runtime JSON DSL."
      ]
    },
    "slides": {
      "path": "./slides",
      "role": "Directory of final slide pages for the concrete deck.",
      "rules": [
        "manifest.json should only point to TSX files in this directory.",
        "AI may edit TSX here directly to adjust layout, component composition, and content mapping.",
        "Slides here may begin as blueprint exports but should be adapted for concrete deck pages."
      ]
    },
    "data": {
      "path": "./data",
      "role": "Content data for demo slides or concrete decks.",
      "rules": [
        "JSON should carry content only, not page-structure decisions.",
        "If layout overflows or a component is unsuitable, prefer editing slides/*.tsx.",
        "Do not invent source-sensitive facts in data JSON; use placeholders or explicitly sourced values."
      ]
    }
  },
  "component_families": [
    "canvas",
    "cover",
    "content-frame",
    "legend",
    "topic-card",
    "metric-card",
    "number-callout",
    "country-card",
    "chart-shell",
