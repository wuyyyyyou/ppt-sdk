{
  "group_id": "red-blue",
  "catalog_type": "tsx-first",
  "version": 2,
  "purpose": "Help the PPT AI Agent choose a copyable red-blue TSX blueprint page first, derive it into slides/*.tsx, and then edit the final slide implementation directly.",
  "directory_roles": {
    "components": {
      "path": "./components",
      "role": "Reusable TSX visual components for the red-blue template group.",
      "rules": [
        "Use these components when building blueprints and concrete slides.",
        "Do not copy raw external snippets, inline scripts, Chart.js, ECharts, or external CDN dependencies into final slides.",
        "Keep component props content-oriented and let slides/*.tsx control page-specific layout."
      ]
    },
    "blueprints": {
      "path": "./blueprints",
      "role": "Directory of copyable TSX blueprint pages.",
      "rules": [
        "Start here by selecting the blueprint page closest to the requested content structure.",
        "Copy or derive it into ./slides before adapting it for a concrete deck.",
        "Do not treat this directory as a runtime JSON DSL."
      ]
    },
    "slides": {
      "path": "./slides",
      "role": "Directory of final slide pages for the concrete deck.",
      "rules": [
        "manifest.json should only point to TSX files in this directory.",
        "AI may edit TSX here directly to adjust layout, component composition, and content mapping.",
        "Slides here may begin as blueprint exports but should be adapted for concrete deck pages."
      ]
    },
    "data": {
      "path": "./data",
      "role": "Content data for demo slides or concrete decks.",
      "rules": [
        "JSON should carry content only, not page-structure decisions.",
        "If layout overflows or a component is unsuitable, prefer editing slides/*.tsx.",
        "Do not invent source-sensitive facts in data JSON; use placeholders or explicitly sourced values."
      ]
    }
  },
  "component_families": [
    "canvas",
    "cover",
    "content-frame",
    "legend",
    "topic-card",
    "metric-card",
    "number-callout",
    "country-card",
    "chart-shell",
    "timeline",
    "roadmap",
    "swot",
    "insight",
    "stat-hero"
  ],
  "blueprints": [
    {
      "id": "cover-statement",
      "name": "Cover Statement",
      "blueprint_source": "./blueprints/CoverStatement.tsx",
      "example_slide": "./slides/CoverStatement.tsx",
      "example_data": "./data/demo/cover-statement.json",
      "layout_family": "cover",
      "content_intents": ["opening", "comparison-positioning", "theme-statement"],
      "suitable_for": ["cover", "market comparison opening", "country comparison opening", "executive briefing opening"],
      "avoid_for": ["body analysis", "dense charts", "comparison matrix", "long process explanation"]
    },
    {
      "id": "agenda-overview",
      "name": "Agenda Overview",
      "blueprint_source": "./blueprints/AgendaOverview.tsx",
      "example_slide": "./slides/AgendaOverview.tsx",
      "example_data": "./data/demo/agenda-overview.json",
      "layout_family": "agenda",
      "content_intents": ["agenda", "section-map", "topic-overview"],
      "suitable_for": ["agenda page", "section overview", "two-to-twelve topic map", "comparison pillar setup"],
      "avoid_for": ["single deep insight", "large chart", "timeline", "closing"]
    },
    {
      "id": "three-topic-cards",
      "name": "Three Topic Cards",
      "blueprint_source": "./blueprints/ThreeTopicCards.tsx",
      "example_slide": "./slides/ThreeTopicCards.tsx",
      "example_data": "./data/demo/three-topic-cards.json",
      "layout_family": "three-card",
      "content_intents": ["categorization", "comparison-lens", "pillars", "executive-summary"],
      "suitable_for": ["three comparison dimensions", "three strategic options", "three findings", "three recommendations"],
      "avoid_for": ["large matrix", "complex timeline", "single chart narrative", "image-led story"]
    },
    {
      "id": "chart-metric-brief",
      "name": "Chart Metric Brief",
      "blueprint_source": "./blueprints/ChartMetricBrief.tsx",
      "example_slide": "./slides/ChartMetricBrief.tsx",
      "example_data": "./data/demo/chart-metric-brief.json",
      "layout_family": "chart-metric",
      "content_intents": ["evidence", "trend", "performance", "benchmark", "metric-readout"],
      "suitable_for": ["one primary chart with interpretation", "KPI benchmark", "trade flow summary", "forecast or trend page", "innovation profile summary"],
      "avoid_for": ["data-free opinion", "agenda", "pure closing", "historical timeline"]
    },
    {
      "id": "country-comparison",
      "name": "Country Comparison",
      "blueprint_source": "./blueprints/CountryComparison.tsx",
      "example_slide": "./slides/CountryComparison.tsx",
      "example_data": "./data/demo/country-comparison.json",
      "layout_family": "country-card-comparison",
      "content_intents": ["comparison", "country-profile", "matched-kpi-fields", "benchmark"],
      "suitable_for": ["two-country comparison", "three-country comparison", "market profile cards", "country capability benchmark"],
      "avoid_for": ["single country deep dive", "long text explanation", "complex sankey or radar chart"]
    },
    {
      "id": "timeline-roadmap",
      "name": "Timeline Roadmap",
      "blueprint_source": "./blueprints/TimelineRoadmap.tsx",
      "example_slide": "./slides/TimelineRoadmap.tsx",
      "example_data": "./data/demo/timeline-roadmap.json",
      "layout_family": "timeline",
      "content_intents": ["history", "sequence", "roadmap", "milestones"],
      "suitable_for": ["historical timeline", "implementation roadmap", "phase plan", "relationship evolution"],
      "avoid_for": ["unordered comparison", "large metric dashboard", "cover", "SWOT"]
    },
    {
      "id": "closing-summary",
      "name": "Closing Summary",
      "blueprint_source": "./blueprints/ClosingSummary.tsx",
      "example_slide": "./slides/ClosingSummary.tsx",
      "example_data": "./data/demo/closing-summary.json",
      "layout_family": "closing",
      "content_intents": ["closing", "summary", "decision-request", "next-steps"],
      "suitable_for": ["decision summary", "next-step page", "final action request"],
      "avoid_for": ["dense evidence", "multi-country matrix", "long narrative"]
    }
  ],
  "agent_workflow_notes": [
    "Read catalog.json first and choose the blueprints/*.tsx file closest to the content structure.",
    "Copy or derive the selected blueprint TSX into slides/*.tsx, then edit the final page directly.",
    "manifest.json source.path should only point to slides/*.tsx.",
    "data/*.json should carry content only; if structure, spacing, or components are unsuitable, edit slides/*.tsx.",
    "Preserve red/blue subject contrast and purple connective accents.",
    "When content includes factual claims, use source-backed data or clearly mark placeholders; do not invent unknown values."
  ]
}
