# Python build / install artefacts (uv tool install . / pip install . / setup.py)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/
.venv/
venv/
env/
executas/*/.build/
executas/*/bundle/

# Test / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# uv / pipx local state (in case anyone runs them inside the example dir)
.uv/
.uv.lock
uv.lock

# Bundle preview server logs
*.log

# Generated by `anna-app dev` / `anna-app apps publish` (Option A
# bundled-executa sidecar): maps bundled handles → tool_ids for the UI bundle.
bundle/anna-tool-ids.js

# Bundled-executa resolution cache (host-scoped minted tool_ids).
.anna/executas.lock.json

# Editor / OS junk
.DS_Store
Thumbs.db
