{
  "schema": 2,
  "permissions": [
    "chat.write_message",
    "tools.invoke"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:file-upload-via-executa",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the Host Upload Demo app open. It demonstrates the host/uploadFile reverse-RPC (inline / negotiate / confirm) via the bundled file-upload-via-executa Executa. The Executa generates a local scratch file (make_sample) and persists it to short-lived host storage (host_upload_path) — bytes go plugin→R2 directly, never through tools.invoke. Objects are transient (~30 min TTL) and not enumerable; the deliverable is the returned short-lived download URL.",
  "tags": ["demo", "storage", "files", "upload", "host-upload", "executa"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Host Upload Demo",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 480, "h": 600 },
        "default_size": { "w": 640, "h": 780 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": ["required:bundled:file-upload-via-executa"],
      "chat": ["write_message"],
      "upload": ["inline", "negotiate", "confirm"],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "script-src": ["'self'"],
      "connect-src": ["'self'", "https:"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "user_id": 1
  }
}
